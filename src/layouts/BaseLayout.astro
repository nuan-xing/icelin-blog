---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

const {
  title = 'icelin',
  description = '生活随笔、摄影作品和个人日记。',
} = Astro.props;

const nav = [
  { href: '/', label: '首页' },
  { href: '/writing/', label: '随笔' },
  { href: '/photos/', label: '摄影' },
  { href: '/about/', label: '关于' },
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title === 'icelin' ? title : `${title} | icelin`}</title>
    <ClientRouter />
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <div class="brand-cluster">
          <a class="brand" href="/" aria-label="icelin 首页">
            <span class="brand-mark"></span>
            <span>icelin</span>
          </a>
          <aside class="music-player" aria-label="Background music player" transition:persist>
            <audio class="music-audio" src="/audio/二人の時間-RADWIMPS.mp3" preload="metadata" loop></audio>
            <button class="music-toggle" type="button" aria-label="Play Time for Two" aria-pressed="false" title="Time for Two">
              <span class="music-icon" aria-hidden="true"></span>
            </button>
          </aside>
        </div>
        <nav class="nav" aria-label="主导航">
          {nav.map((item) => <a href={item.href}>{item.label}</a>)}
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <span>© {new Date().getFullYear()} icelin</span>
        <span>记录生活，收藏光线。</span>
      </footer>
    </div>
    <script>
      declare global {
        interface Window {
          __icelinBindMotion?: (cards: HTMLElement[]) => void;
          __icelinMasonryTimer?: number;
          __icelinResizeBound?: boolean;
        }
      }

      const setupMusic = () => {
        const musicRoot = document.querySelector<HTMLElement>('.music-player');
        const musicAudio = musicRoot?.querySelector<HTMLAudioElement>('.music-audio');
        const musicToggle = musicRoot?.querySelector<HTMLButtonElement>('.music-toggle');

        if (!musicRoot || !musicAudio || !musicToggle) return;

        musicAudio.volume = 0.6;

        const setMusicUi = (isPlaying: boolean) => {
          musicRoot.classList.toggle('is-playing', isPlaying);
          musicToggle.setAttribute('aria-pressed', String(isPlaying));
          musicToggle.setAttribute('aria-label', isPlaying ? 'Pause Time for Two' : 'Play Time for Two');
        };

        setMusicUi(!musicAudio.paused);

        if (musicRoot.dataset.musicBound === 'true') return;
        musicRoot.dataset.musicBound = 'true';

        const tryAutoplay = async () => {
          if (!musicAudio.paused) return;

          try {
            await musicAudio.play();
            setMusicUi(true);
          } catch {
            setMusicUi(false);
          }
        };

        void tryAutoplay();

        musicToggle.addEventListener('click', async () => {
          if (!musicAudio.paused) {
            musicAudio.pause();
            setMusicUi(false);
            return;
          }

          try {
            await musicAudio.play();
            setMusicUi(true);
          } catch {
            setMusicUi(false);
          }
        });

        musicAudio.addEventListener('play', () => setMusicUi(true));
        musicAudio.addEventListener('pause', () => setMusicUi(false));
        musicAudio.addEventListener('error', () => setMusicUi(false));
      };

      const setupMotion = () => {
        const motionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
        if (motionQuery.matches) return;

        document.documentElement.classList.add('js-motion');

        const revealObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              entry.target.classList.add('is-visible');
              window.setTimeout(() => {
                if (entry.target instanceof HTMLElement) {
                  entry.target.style.transitionDelay = '0ms';
                }
              }, 780);
              revealObserver.unobserve(entry.target);
            });
          },
          {
            threshold: 0.18,
            rootMargin: '0px 0px -8% 0px',
          },
        );

        const observeReveal = (card: HTMLElement, index: number) => {
          if (card.dataset.revealBound === 'true') return;
          card.dataset.revealBound = 'true';
          card.style.transitionDelay = `${Math.min(index * 90, 360)}ms`;
          revealObserver.observe(card);
        };

        const bindMagnet = (card: HTMLElement) => {
          if (card.dataset.magnetBound === 'true') return;
          card.dataset.magnetBound = 'true';
          card.addEventListener('pointermove', (event: PointerEvent) => {
            const rect = card.getBoundingClientRect();
            const isHeaderItem = card.classList.contains('brand') || card.closest('.nav');
            const isPhotoCard = card.classList.contains('photo-card');
            const strengthX = isHeaderItem ? 5 : card.classList.contains('feature-link') ? 8 : isPhotoCard ? 7 : 10;
            const strengthY = isHeaderItem ? 4 : card.classList.contains('feature-link') ? 6 : isPhotoCard ? 5 : 8;
            const x = ((event.clientX - rect.left) / rect.width - 0.5) * strengthX;
            const y = ((event.clientY - rect.top) / rect.height - 0.5) * strengthY;
            card.style.setProperty('--magnet-x', `${x.toFixed(2)}px`);
            card.style.setProperty('--magnet-y', `${y.toFixed(2)}px`);
          });

          card.addEventListener('pointerleave', () => {
            card.style.setProperty('--magnet-x', '0px');
            card.style.setProperty('--magnet-y', '0px');
          });
        };

        document.querySelectorAll<HTMLElement>('.post-row, .feature-link').forEach(observeReveal);
        document.querySelectorAll<HTMLElement>('.post-row, .feature-link, .brand, .nav a').forEach(bindMagnet);

        window.__icelinBindMotion = (cards: HTMLElement[]) => {
          cards.forEach((card, index) => {
            observeReveal(card, index);
            bindMagnet(card);
          });
        };
      };

      const setupMasonry = () => {
        document.querySelectorAll<HTMLElement>('[data-masonry]').forEach((grid) => {
          const existingCards = [...grid.querySelectorAll<HTMLElement>('.photo-card')];
          if (existingCards.length === 0) return;

          const cards = existingCards.map((card) => {
            card.style.removeProperty('width');
            return card;
          });

          grid.classList.remove('is-masonry');
          grid.replaceChildren(...cards);

          const columnCount = window.matchMedia('(max-width: 760px)').matches ? 1 : 2;
          const columns = Array.from({ length: columnCount }, () => {
            const column = document.createElement('div');
            column.className = 'photo-column';
            return column;
          });

          grid.classList.add('is-masonry');
          grid.replaceChildren(...columns);

          const heights = new Array(columnCount).fill(0);
          cards.forEach((card) => {
            const targetIndex = heights.indexOf(Math.min(...heights));
            columns[targetIndex].append(card);
            heights[targetIndex] += card.getBoundingClientRect().height;
          });

          window.__icelinBindMotion?.(cards);
        });
      };

      const scheduleMasonry = () => window.requestAnimationFrame(setupMasonry);

      const setupPage = () => {
        setupMusic();
        setupMotion();
        scheduleMasonry();
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', setupPage, { once: true });
      } else {
        setupPage();
      }

      document.addEventListener('astro:page-load', setupPage);
      window.addEventListener('load', scheduleMasonry);

      if (!window.__icelinResizeBound) {
        window.__icelinResizeBound = true;
        window.addEventListener('resize', () => {
          window.clearTimeout(window.__icelinMasonryTimer);
          window.__icelinMasonryTimer = window.setTimeout(scheduleMasonry, 120);
        });
      }
    </script>
  </body>
</html>
