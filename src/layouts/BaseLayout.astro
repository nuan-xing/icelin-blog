---
import '../styles/global.css';

const {
  title = 'icelin',
  description = '生活随笔、摄影作品和个人日记。',
} = Astro.props;

const nav = [
  { href: '/', label: '首页' },
  { href: '/writing/', label: '随笔' },
  { href: '/photos/', label: '摄影' },
  { href: '/about/', label: '关于' },
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title === 'icelin' ? title : `${title} | icelin`}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <a class="brand" href="/" aria-label="icelin 首页">
          <span class="brand-mark"></span>
          <span>icelin</span>
        </a>
        <nav class="nav" aria-label="主导航">
          {nav.map((item) => <a href={item.href}>{item.label}</a>)}
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <span>© {new Date().getFullYear()} icelin</span>
        <span>记录生活，收藏光线。</span>
      </footer>
    </div>
    <script>
      const motionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');

      if (!motionQuery.matches) {
        document.documentElement.classList.add('js-motion');

        const motionCards = [...document.querySelectorAll<HTMLElement>('.post-row, .feature-link')];

        const revealObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              entry.target.classList.add('is-visible');
              window.setTimeout(() => {
                if (entry.target instanceof HTMLElement) {
                  entry.target.style.transitionDelay = '0ms';
                }
              }, 780);
              revealObserver.unobserve(entry.target);
            });
          },
          {
            threshold: 0.18,
            rootMargin: '0px 0px -8% 0px',
          },
        );

        motionCards.forEach((card, index) => {
          card.style.transitionDelay = `${Math.min(index * 90, 360)}ms`;
          revealObserver.observe(card);

          card.addEventListener('pointermove', (event: PointerEvent) => {
            const rect = card.getBoundingClientRect();
            const strengthX = card.classList.contains('feature-link') ? 8 : 10;
            const strengthY = card.classList.contains('feature-link') ? 6 : 8;
            const x = ((event.clientX - rect.left) / rect.width - 0.5) * strengthX;
            const y = ((event.clientY - rect.top) / rect.height - 0.5) * strengthY;
            card.style.setProperty('--magnet-x', `${x.toFixed(2)}px`);
            card.style.setProperty('--magnet-y', `${y.toFixed(2)}px`);
          });

          card.addEventListener('pointerleave', () => {
            card.style.setProperty('--magnet-x', '0px');
            card.style.setProperty('--magnet-y', '0px');
          });
        });
      }
    </script>
  </body>
</html>
